{
  "name": "hackerrank-study",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "catalog:generate": "npm run catalog:generate --prefix frontend",
    "backfill:project-tests": "node frontend/scripts/backfill-project-tests-json.mjs",
    "verify:project-tests": "node frontend/scripts/verify-project-tests.mjs --check-schema",
    "test": "node --test tests/**/*.test.mjs",
    "test:graph": "node --test tests/graph/*.test.mjs",
    "test:validate": "node --test tests/validate/*.test.mjs",
    "test:catalog": "node --test tests/catalog/*.test.mjs",
    "test:integration": "node --test tests/integration/*.test.mjs",
    "test:plugins": "node --test tests/plugins/*.test.mjs",
    "test:migrate": "node --test tests/migrate/*.test.mjs",
    "test:selectors": "node --test tests/selectors/*.test.mjs",
    "test:navigation": "node --test tests/navigation/*.test.mjs"
  }
}
